# Node modules
node_modules/

# JSON config files (except package.json and package-lock.json)
*.json
!package.json
!package-lock.json

# Specific JSON files to ignore (alternative approach)
antiviewonce_config.json
auto_join_log.json
owner.json

# Data directory
data/

# Session files — never overwrite with git pull
session/

# Environment variables — contains SESSION_ID, never overwrite with git pull
.env

# Optional: OS files
.DS_Store
Thumbs.db

# Optional: IDE files
.vscode/
.idea/
